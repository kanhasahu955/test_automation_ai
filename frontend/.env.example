# Dev: use /api/v1 (relative) so Vite proxies /api and /socket.io to the backend — same origin, no CORS issues.
# If you use a full URL to :8000 instead, add your exact page origin (e.g. http://127.0.0.1:3000) to backend CORS_ORIGINS,
# or set VITE_SOCKET_SAME_ORIGIN=true and still proxy /socket.io on the dev server.
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY=http://localhost:8000
# VITE_SOCKET_SAME_ORIGIN=true
