{
  "info": {
    "_postman_id": "qf-ai-collection-001",
    "name": "QualityForge AI",
    "description": "Complete REST surface for QualityForge AI (prefix /api/v1).\n\nUsage:\n1. Import the companion environment file `qualityforge-ai.postman_environment.json`.\n2. Run **Auth → Login (JSON)** — the `accessToken`, `refreshToken`, and `userId` are auto-populated by the test script.\n3. Other requests inherit Bearer auth from the collection.\n\nVariables: `baseUrl`, `accessToken`, `refreshToken`, `userId`, `projectId`, `environmentId`, `dataSourceId`, `testCaseId`, `suiteId`, `flowId`, `runId`, `stmDocumentId`, `stmMappingId`, `qualityRuleId`, `metadataTableId`, `sqlTestId`, `profilingRunId`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "environmentId", "value": "" },
    { "key": "dataSourceId", "value": "" },
    { "key": "testCaseId", "value": "" },
    { "key": "suiteId", "value": "" },
    { "key": "flowId", "value": "" },
    { "key": "runId", "value": "" },
    { "key": "stmDocumentId", "value": "" },
    { "key": "stmMappingId", "value": "" },
    { "key": "qualityRuleId", "value": "" },
    { "key": "metadataTableId", "value": "" },
    { "key": "sqlTestId", "value": "" },
    { "key": "profilingRunId", "value": "" }
  ],
