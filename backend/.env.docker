# =============================================================================
# Docker mode — snapshot of `backend/.env` used when running inside compose
# (containers reach each other by service name on the qf_net bridge).
# Switch the active env with:  make use-docker-env
# =============================================================================

# ====== App ======
APP_NAME=QualityForge AI
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ====== Security ======
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=14
PASSWORD_PEPPER=change-me-pepper
ENCRYPTION_KEY=ZmFrZS1lbmNyeXB0aW9uLWtleS1jaGFuZ2UtbWUtMzItYnl0ZXM=

# ====== Database (MySQL) — service name `mysql` inside compose network ======
DB_HOST=mysql
DB_PORT=3306
DB_USER=qfuser
DB_PASSWORD=qfpass
DB_NAME=qualityforge
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_CONNECT_TIMEOUT_S=10

# ====== Redis / Celery — service name `redis` inside compose network ======
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ====== Operational dashboards ======
FLOWER_URL=http://localhost:5555
REDIS_COMMANDER_URL=http://localhost:8081
AIRFLOW_URL=http://localhost:8088

# ====== Storage / Artifacts ======
ARTIFACTS_DIR=/var/qf/artifacts
UPLOADS_DIR=/var/qf/uploads

# ====== AI ======
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-nano
AI_ENABLED=true

# ====== Worker / data tuning ======
METADATA_MAX_TABLES=100
PROFILING_MAX_TABLES=50
PROFILING_SAMPLE_SIZE=1000
REPORT_RECENT_RUNS_LIMIT=50
STM_VALIDATION_FETCH=50

# ====== Bootstrap admin ======
BOOTSTRAP_ADMIN_EMAIL=admin@qualityforge.ai
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
BOOTSTRAP_ADMIN_NAME=Platform Admin
