# =============================================================================
# Host mode — used when the backend runs directly on macOS via `make api`.
#
# Talks to:
#   • MySQL  on 127.0.0.1:3306 (your locally-installed MySQL — Homebrew/manual)
#   • Redis  on 127.0.0.1:6379 (Homebrew or `make infra-up` brings the docker one)
#
# One-time bootstrap of your local MySQL (creates DB + qfuser):
#   make db-create-local                              # root has no password
#   make db-create-local MYSQL_LOCAL_ROOT_PASSWORD=…  # if root is protected
#
# Activate this profile:   make use-host-env
# Then create tables:      make db-init
# Verify connection:       make db-ping
#
# If instead you want host-mode to talk to the dockerized MySQL exposed by
# `make infra-up`, change DB_PORT to 3307 (the compose port mapping).
# =============================================================================

# ====== App ======
APP_NAME=QualityForge AI
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ====== Security ======
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=14
PASSWORD_PEPPER=change-me-pepper
ENCRYPTION_KEY=ZmFrZS1lbmNyeXB0aW9uLWtleS1jaGFuZ2UtbWUtMzItYnl0ZXM=

# ====== Database (MySQL) — your locally installed instance ======
# Default credentials match backend/sql/init/01_create_database.sql.
# Change DB_USER/DB_PASSWORD here AND in that SQL file if you want different ones.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=qualityforge
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_CONNECT_TIMEOUT_S=10

# ====== Redis / Celery — host-side ======
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ====== Operational dashboards ======
FLOWER_URL=http://localhost:5555
REDIS_COMMANDER_URL=http://localhost:8081
AIRFLOW_URL=http://localhost:8088

# ====== Storage / Artifacts (writable host dirs) ======
ARTIFACTS_DIR=./.local/artifacts
UPLOADS_DIR=./.local/uploads

# ====== AI ======
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-nano
AI_ENABLED=true

# ====== Worker / data tuning ======
METADATA_MAX_TABLES=100
PROFILING_MAX_TABLES=50
PROFILING_SAMPLE_SIZE=1000
REPORT_RECENT_RUNS_LIMIT=50
STM_VALIDATION_FETCH=50

# ====== Bootstrap admin ======
BOOTSTRAP_ADMIN_EMAIL=admin@qualityforge.ai
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
BOOTSTRAP_ADMIN_NAME=Platform Admin
